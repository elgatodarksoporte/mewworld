{
  "name": "radio-247",
  "version": "1.2.1",
  "description": "Radio 24/7 - Desktop App",
  "repository": "https://github.com/elgatodarksoporte/mewworld",
  "author": "elgatodarksoporte",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.mewworld.radio247",
    "productName": "Radio 247",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "offline.html",
      "mini-player.html",
      "icon.png",
      "icon.ico",
      "installer-sidebar.bmp",
      "installer-header.bmp"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerSidebar": "installer-sidebar.bmp",
      "installerHeaderIcon": "icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Radio 24/7"
    },
    "publish": {
      "provider": "github",
      "owner": "elgatodarksoporte",
      "repo": "mewworld"
    }
  },
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.8.3"
  }
}
